        "jsCode": "const prev = $json.attempts || 0;\nconst interval = $json.poll_interval_seconds || 5;\nconst elapsed = prev * interval;\n\nif (elapsed >= ($json.max_poll_seconds || 300)) {\n  throw new Error('D-ID polling budget exceeded \u2014 video generation took too long.');\n}\n\nreturn [{\n  json: {\n    ...$json,\n    attempts: prev + 1\n  }\n}];"
