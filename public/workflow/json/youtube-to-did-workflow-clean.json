{
  "name": "YouTube to D-ID Creator Shorts Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "youtube-to-heygen",
        "responseMode": "lastNode",
        "options": {}
      },
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -3264,
        256
      ],
      "id": "114dbc61-9049-466a-9e81-67b49dfcef76",
      "name": "Webhook Trigger",
      "webhookId": "f0e1d2c3-b4a5-6789-0abc-def012345678"
    },
    {
      "parameters": {
        "jsCode": "// Extract Video ID & Thumbnail URL from YouTube URL\nconst youtubeUrl = $json.body.youtube_url || $json.youtube_url || '';\nconst creatorName = $json.body.creator_name || $json.creator_name || 'Creator';\n\n// Extract VIDEO_ID using regex (handles standard, short, and embed URLs)\nconst regex = /(?:youtu\\.be\\/|youtube\\.com\\/(?:watch\\?v=|embed\\/|v\\/|shorts\\/))([a-zA-Z0-9_-]{11})/;\nconst match = youtubeUrl.match(regex);\n\nif (!match || !match[1]) {\n  throw new Error(`Could not extract Video ID from URL: ${youtubeUrl}`);\n}\n\nconst videoId = match[1];\nconst thumbnailUrl = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;\n\nreturn [{\n  json: {\n    youtube_url: youtubeUrl,\n    creator_name: creatorName,\n    video_id: videoId,\n    thumbnail_url: thumbnailUrl\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3024,
        256
      ],
      "id": "8f7bf8ea-b32e-4a5c-9251-84af1bd43ea7",
      "name": "Extract Video ID & Image"
    },
    {
      "parameters": {
        "url": "https://youtube-mp36.p.rapidapi.com/dl",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "id",
              "value": "={{ $json.video_id }}"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-RapidAPI-Key",
              "value": "YOUR_API_KEY_HERE"
            },
            {
              "name": "X-RapidAPI-Host",
              "value": "youtube-mp36.p.rapidapi.com"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -2784,
        256
      ],
      "id": "dc161822-db9f-4362-814e-229d46f80055",
      "name": "YouTube Audio Extraction"
    },
    {
      "parameters": {
        "jsCode": "// Extract the audio download link from the RapidAPI response\nconst link = $json.link || $json.url || $json.download_url || '';\nconst status = $json.status;\nconst prevData = $('Extract Video ID & Image').first().json;\n\nif (!link && status === 'processing') {\n  return [{\n    json: {\n      youtube_url: prevData.youtube_url,\n      creator_name: prevData.creator_name,\n      video_id: prevData.video_id,\n      thumbnail_url: prevData.thumbnail_url,\n      audio_download_url: null,\n      audio_status: status\n    }\n  }];\n}\n\nif (!link) {\n  throw new Error('YouTube MP3 API did not return a download link. Response: ' + JSON.stringify($json));\n}\n\nreturn [{\n  json: {\n    youtube_url: prevData.youtube_url,\n    creator_name: prevData.creator_name,\n    video_id: prevData.video_id,\n    thumbnail_url: prevData.thumbnail_url,\n    audio_download_url: link,\n    audio_status: status\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2544,
        256
      ],
      "id": "1018be6a-7a9b-4027-860b-d0b0c7917e2f",
      "name": "Parse Audio URL"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent?key=AIzaSyD5YpKha29ePOPOcUx5TVl7xvO1uPNvA54",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  contents: [\n    {\n      parts: [\n        {\n          text: \"Write a 60-second engaging short-form video script for the creator '\" + $json.creator_name + \"'. The script should be exactly 130 words. Do not include stage directions, just the spoken text. Make it energetic, hook-driven, and suitable for YouTube Shorts or TikTok.\"\n        }\n      ]\n    }\n  ]\n}) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 60000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -2160,
        256
      ],
      "id": "558607d8-e115-42c3-b72f-8692736d048e",
      "name": "Gemini Script Generation"
    },
    {
      "parameters": {
        "jsCode": "// Parse the Gemini response to extract the script text\nconst candidates = $json.candidates || [];\nconst text = candidates?.[0]?.content?.parts?.[0]?.text || '';\nconst script = text.trim().slice(0, 1400);\n\nif (!script) {\n  throw new Error('Empty script returned from Gemini API');\n}\n\n// Carry forward data from earlier nodes\nconst prevData = $('Parse Audio URL').first().json;\n\nreturn [{\n  json: {\n    youtube_url: prevData.youtube_url,\n    creator_name: prevData.creator_name,\n    video_id: prevData.video_id,\n    thumbnail_url: prevData.thumbnail_url,\n    audio_download_url: prevData.audio_download_url,\n    script_text: script\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1840,
        256
      ],
      "id": "4d04ac72-5313-45b6-b802-16c8f99daf46",
      "name": "Parse Gemini Script"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.d-id.com/talks",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "YOUR_API_KEY_HERE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  \"source_url\": $json.thumbnail_url,\n  \"script\": {\n    \"type\": \"text\",\n    \"input\": $json.script_text\n  }\n}) }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          },
          "timeout": 60000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -1360,
        256
      ],
      "id": "did-create-talk-001",
      "name": "D-ID Create Talk"
    },
    {
      "parameters": {
        "jsCode": "const talkId = $json.id || '';\nif (!talkId) {\n  throw new Error('D-ID did not return talk ID. Response: ' + JSON.stringify($json));\n}\nconst prevData = $('Parse Gemini Script').first().json;\nreturn [{\n  json: {\n    did_talk_id: talkId,\n    attempts: 0,\n    max_poll_seconds: 300,\n    poll_interval_seconds: 5,\n    youtube_url: prevData.youtube_url,\n    creator_name: prevData.creator_name,\n    video_id: prevData.video_id,\n    thumbnail_url: prevData.thumbnail_url,\n    script_text: prevData.script_text\n  }\n}];"
      },
